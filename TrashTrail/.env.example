# TrashTrail — Environment Variable Template
# Copy this file to .env.local and fill in your actual credentials.

# Database URI (Only needed if you switch back to MongoDB)
MONGODB_URI="mongodb://localhost:27017/trashtrail_dev"

# Authentication Secrets
NEXTAUTH_SECRET="REPLACE_WITH_A_SECURE_SECRET_STING"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (Optional - For Image Hosting)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# AI Engine (Google Gemini 1.5)
GEMINI_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
